RewriteEngine On

# Force correct MIME types (LiteSpeed + Apache compatible)
RewriteRule \.m?js$ - [T=text/javascript,L]
RewriteRule \.css$ - [T=text/css,L]

# SPA routing — all paths → index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]
